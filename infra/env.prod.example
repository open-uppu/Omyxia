# Omyxia Production Environment Template
# Copy to .env.prod and fill in values

# ===== Domain =====
DOMAIN=omyxia.example.com
WEB_URL=https://omyxia.example.com
CORS_ORIGIN=https://omyxia.example.com

# ===== Database =====
POSTGRES_USER=omyxia
POSTGRES_PASSWORD=CHANGE_ME_random_32_bytes_hex
POSTGRES_DB=omyxia

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== MinIO / S3 =====
MINIO_ROOT_USER=omyxia_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_random_32_bytes_hex
MINIO_PUBLIC_URL=https://minio.omyxia.example.com

# ===== Auth =====
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_32_bytes_hex
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ===== SMTP / IMAP (Stalwart) =====
SMTP_USER=noreply@omyxia.example.com
SMTP_PASS=CHANGE_ME_random_password
STALWART_HOSTNAME=mail.omyxia.example.com
STALWART_DOMAIN=omyxia.example.com