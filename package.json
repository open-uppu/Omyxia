{
  "name": "omyxia",
  "version": "0.3.1",
  "private": true,
  "description": "Omyxia — Multi-tenant Enterprise IT Master Blueprint (SaaS) — OSS-first, RLS-enforced tenant isolation",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @omyxia/prisma db:migrate",
    "db:seed": "pnpm --filter @omyxia/prisma db:seed",
    "db:studio": "pnpm --filter @omyxia/prisma db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/websockets": "^10.4.0",
    "ioredis": "^5.11.1"
  }
}
