generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [citext(schema: "public")]
}

model Tenant {
  id                 String               @id @default(cuid())
  slug               String               @unique
  name               String
  plan               TenantPlan           @default(STARTER)
  status             TenantStatus         @default(ACTIVE)
  settings           Json                 @default("{}")
  createdAt          DateTime             @default(now()) @db.Timestamp(6)
  updatedAt          DateTime             @default(now()) @updatedAt @db.Timestamp(6)
  ApBill             ApBill[]
  ArInvoice          ArInvoice[]
  AttendanceRecord   AttendanceRecord[]
  BackupRecord       BackupRecord[]
  CashFlowForecast   CashFlowForecast[]
  ChartOfAccounts    ChartOfAccounts[]
  ChatChannel        ChatChannel[]
  ChatChannelMember  ChatChannelMember[]
  ChatMessage        ChatMessage[]
  ConsentRecord      ConsentRecord[]
  CookieConsent      CookieConsent[]
  CreditAssessment   CreditAssessment[]
  CrmActivity        CrmActivity[]
  CrmLead            CrmLead[]
  CrmPipeline        CrmPipeline[]
  Customer           Customer[]
  CustomerEvent      CustomerEvent[]
  CustomerProfile    CustomerProfile[]
  Dashboard          Dashboard[]
  DataBreachIncident DataBreachIncident[]
  DataSubjectRequest DataSubjectRequest[]
  departments        Department[]
  Device             Device[]
  DocumentInstance   DocumentInstance[]
  DocumentTemplate   DocumentTemplate[]
  EmailMessage       EmailMessage[]
  EmailTemplate      EmailTemplate[]
  employees          Employee[]
  FileFolder         FileFolder[]
  FileItem           FileItem[]
  FiscalPeriod       FiscalPeriod[]
  FraudAlert         FraudAlert[]
  InventoryItem      InventoryItem[]
  Invoice            Invoice[]
  JournalEntry       JournalEntry[]
  JournalLine        JournalLine[]
  KpiDefinition      KpiDefinition[]
  KpiSnapshot        KpiSnapshot[]
  LeaveQuota         LeaveQuota[]
  LeaveRequest       LeaveRequest[]
  MarketingCampaign  MarketingCampaign[]
  PayrollLine        PayrollLine[]
  PayrollPeriod      PayrollPeriod[]
  positions          Position[]
  PrivacyPolicy      PrivacyPolicy[]
  Project            Project[]
  ProjectTask        ProjectTask[]
  ReportSnapshot     ReportSnapshot[]
  StockMovement      StockMovement[]
  SupplierScore      SupplierScore[]
  TaxRate            TaxRate[]
  TaxTransaction     TaxTransaction[]
  ThreatEvent        ThreatEvent[]
  Ticket             Ticket[]
  users              UserTenant[]
  Vehicle            Vehicle[]
  VehicleTrip        VehicleTrip[]
  Vendor             Vendor[]
  Warehouse          Warehouse[]

  @@index([status], map: "idx_tenant_status")
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique @db.Citext
  emailVerified     DateTime?           @db.Timestamp(6)
  passwordHash      String
  name              String
  locale            String              @default("th")
  avatarUrl         String?
  lastLoginAt       DateTime?           @db.Timestamp(6)
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  updatedAt         DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  ChatChannelMember ChatChannelMember[]
  ChatMessage       ChatMessage[]
  CrmActivity       CrmActivity[]
  CrmLead           CrmLead[]
  EmailMessage      EmailMessage[]
  Employee          Employee[]
  FileFolder        FileFolder[]
  FileItem          FileItem[]
  mfaFactors        MfaFactor[]
  refreshTokens     RefreshToken[]
  sessions          UserSession[]
  tenants           UserTenant[]

  @@index([email], map: "idx_user_email")
}

model UserTenant {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(MEMBER)
  active   Boolean    @default(true)
  joinedAt DateTime   @default(now()) @db.Timestamp(6)
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, userId])
  @@index([tenantId], map: "idx_user_tenant_tenant")
  @@index([userId], map: "idx_user_tenant_user")
}

model UserSession {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  activeTenantId String?
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime @db.Timestamp(6)
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_user_session_expires")
  @@index([token], map: "idx_user_session_token")
  @@index([userId], map: "idx_user_session_user")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime @db.Timestamp(6)
  revokedAt DateTime? @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_refresh_token_user")
  @@index([expiresAt], map: "idx_refresh_token_expires")
}

model Employee {
  id               String             @id @default(cuid())
  tenantId         String
  userId           String?
  employeeNo       String
  firstName        String
  lastName         String
  thFirstName      String?
  thLastName       String?
  email            String?
  nationalId       String?
  taxId            String?
  socialSecurityNo String?
  hireDate         DateTime           @db.Timestamp(6)
  terminationDate  DateTime?          @db.Timestamp(6)
  employmentType   EmploymentType     @default(FULL_TIME)
  baseSalary       Decimal?           @default(0) @db.Decimal(15, 2)
  departmentId     String?
  positionId       String?
  managerId        String?
  status           EmployeeStatus     @default(ACTIVE)
  createdAt        DateTime           @default(now()) @db.Timestamp(6)
  updatedAt        DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  attendance       AttendanceRecord[]
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User             User?              @relation(fields: [userId], references: [id], onUpdate: NoAction)
  LeaveQuota       LeaveQuota[]
  leaveRequests    LeaveRequest[]
  payrollLines     PayrollLine[]

  @@unique([tenantId, employeeNo])
  @@unique([tenantId, email])
  @@unique([tenantId, nationalId])
  @@index([tenantId], map: "idx_employee_tenant")
  @@index([tenantId, departmentId], map: "idx_employee_tenant_dept")
  @@index([tenantId, managerId], map: "idx_employee_tenant_mgr")
  @@index([tenantId, status], map: "idx_employee_tenant_status")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  parentId  String?
  managerId String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_department_tenant")
  @@index([tenantId, parentId], map: "idx_department_tenant_parent")
}

model Position {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  title     String
  level     Int      @default(1)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_position_tenant")
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime         @db.Timestamp(6)
  clockIn     DateTime?        @db.Timestamp(6)
  clockOut    DateTime?        @db.Timestamp(6)
  hoursWorked Decimal?         @db.Decimal(5, 2)
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  createdAt   DateTime         @default(now()) @db.Timestamp(6)
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId], map: "idx_attendance_tenant")
  @@index([tenantId, date], map: "idx_attendance_tenant_date")
}

model LeaveRequest {
  id         String      @id @default(cuid())
  tenantId   String
  employeeId String
  leaveType  LeaveType
  startDate  DateTime    @db.Timestamp(6)
  endDate    DateTime    @db.Timestamp(6)
  days       Int
  reason     String?
  status     LeaveStatus @default(PENDING)
  approverId String?
  approvedAt DateTime?   @db.Timestamp(6)
  createdAt  DateTime    @default(now()) @db.Timestamp(6)
  updatedAt  DateTime    @default(now()) @updatedAt @db.Timestamp(6)
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_leave_tenant")
  @@index([tenantId, employeeId], map: "idx_leave_tenant_employee")
  @@index([tenantId, status], map: "idx_leave_tenant_status")
}

model LeaveQuota {
  id         String    @id @default(cuid())
  tenantId   String
  employeeId String
  leaveType  LeaveType
  year       Int
  quotaDays  Int
  usedDays   Int       @default(0)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  Employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, employeeId, leaveType, year])
  @@index([tenantId], map: "idx_leave_quota_tenant")
}

model PayrollPeriod {
  id          String        @id @default(cuid())
  tenantId    String
  periodStart DateTime      @db.Timestamp(6)
  periodEnd   DateTime      @db.Timestamp(6)
  status      PayrollStatus @default(DRAFT)
  approvedBy  String?
  approvedAt  DateTime?     @db.Timestamp(6)
  paidAt      DateTime?     @db.Timestamp(6)
  createdAt   DateTime      @default(now()) @db.Timestamp(6)
  updatedAt   DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  lines       PayrollLine[]
  Tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, periodStart])
  @@index([tenantId], map: "idx_payroll_tenant")
}

model PayrollLine {
  id             String        @id @default(cuid())
  tenantId       String
  periodId       String
  employeeId     String
  baseSalary     Decimal       @db.Decimal(15, 2)
  overtime       Decimal       @default(0) @db.Decimal(15, 2)
  bonus          Decimal       @default(0) @db.Decimal(15, 2)
  allowances     Decimal       @default(0) @db.Decimal(15, 2)
  deductions     Decimal       @default(0) @db.Decimal(15, 2)
  tax            Decimal       @default(0) @db.Decimal(15, 2)
  socialSecurity Decimal       @default(0) @db.Decimal(15, 2)
  netPay         Decimal       @db.Decimal(15, 2)
  details        Json          @default("{}")
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  period         PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([periodId, employeeId])
  @@index([periodId], map: "idx_payroll_line_period")
  @@index([tenantId], map: "idx_payroll_line_tenant")
}

model ChartOfAccounts {
  id            String        @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          AccountType
  normalBalance NormalBalance @default(DEBIT)
  parentId      String?
  currency      String        @default("THB")
  isActive      Boolean       @default(true)
  isPostable    Boolean       @default(true)
  path          String        @default("/")
  createdAt     DateTime      @default(now()) @db.Timestamp(6)
  updatedAt     DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  Tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  JournalLine   JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_account_tenant")
  @@index([tenantId, parentId], map: "idx_account_tenant_parent")
  @@index([tenantId, type], map: "idx_account_tenant_type")
}

model JournalEntry {
  id          String        @id @default(cuid())
  tenantId    String
  entryNo     String
  date        DateTime      @db.Timestamp(6)
  description String
  reference   String?
  status      JournalStatus @default(DRAFT)
  approvedBy  String?
  approvedAt  DateTime?     @db.Timestamp(6)
  createdAt   DateTime      @default(now()) @db.Timestamp(6)
  updatedAt   DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  Tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lines       JournalLine[]

  @@unique([tenantId, entryNo])
  @@index([tenantId], map: "idx_journal_tenant")
  @@index([tenantId, date], map: "idx_journal_tenant_date")
  @@index([tenantId, status], map: "idx_journal_tenant_status")
}

model JournalLine {
  id              String          @id @default(cuid())
  tenantId        String
  entryId         String
  accountId       String
  debit           Decimal         @default(0) @db.Decimal(15, 2)
  credit          Decimal         @default(0) @db.Decimal(15, 2)
  description     String?
  costCenter      String?
  project         String?
  createdAt       DateTime        @default(now()) @db.Timestamp(6)
  ChartOfAccounts ChartOfAccounts @relation(fields: [accountId], references: [id], onUpdate: NoAction)
  entry           JournalEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([entryId], map: "idx_journal_line_entry")
  @@index([tenantId], map: "idx_journal_line_tenant")
}

model FiscalPeriod {
  id        String             @id @default(cuid())
  tenantId  String
  startDate DateTime           @db.Timestamp(6)
  endDate   DateTime           @db.Timestamp(6)
  status    FiscalPeriodStatus @default(OPEN)
  closedAt  DateTime?          @db.Timestamp(6)
  closedBy  String?
  createdAt DateTime           @default(now()) @db.Timestamp(6)
  Tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, startDate])
  @@index([tenantId], map: "idx_fiscal_tenant")
}

model TaxRate {
  id             String           @id @default(cuid())
  tenantId       String
  type           TaxType
  name           String
  rate           Decimal          @db.Decimal(5, 2)
  effectiveFrom  DateTime         @db.Timestamp(6)
  effectiveTo    DateTime?        @db.Timestamp(6)
  createdAt      DateTime         @default(now()) @db.Timestamp(6)
  Tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  TaxTransaction TaxTransaction[]

  @@unique([tenantId, type, effectiveFrom])
  @@index([tenantId], map: "idx_tax_rate_tenant")
}

model TaxTransaction {
  id            String    @id @default(cuid())
  tenantId      String
  taxRateId     String
  sourceType    String
  sourceId      String
  baseAmount    Decimal   @db.Decimal(15, 2)
  taxAmount     Decimal   @db.Decimal(15, 2)
  certificateNo String?
  filedAt       DateTime? @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  TaxRate       TaxRate   @relation(fields: [taxRateId], references: [id], onUpdate: NoAction)
  Tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, sourceType, sourceId], map: "idx_tax_tx_source")
  @@index([tenantId], map: "idx_tax_tx_tenant")
}

model Vendor {
  id            String          @id @default(cuid())
  tenantId      String
  code          String
  name          String
  taxId         String?
  email         String?
  phone         String?
  address       String?
  paymentTerms  Int             @default(30)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now()) @db.Timestamp(6)
  updatedAt     DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  bills         ApBill[]
  Invoice       Invoice[]
  SupplierScore SupplierScore[]
  Tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_vendor_tenant")
}

model Customer {
  id           String      @id @default(cuid())
  tenantId     String
  code         String
  name         String
  taxId        String?
  email        String?
  phone        String?
  address      String?
  creditLimit  Decimal     @default(0) @db.Decimal(15, 2)
  paymentTerms Int         @default(30)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now()) @db.Timestamp(6)
  updatedAt    DateTime    @default(now()) @updatedAt @db.Timestamp(6)
  invoices     ArInvoice[]
  CrmLead      CrmLead[]
  Tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@index([tenantId], map: "idx_customer_tenant")
}

model ArInvoice {
  id          String          @id @default(cuid())
  tenantId    String
  customerId  String?
  invoiceNo   String
  invoiceDate DateTime        @db.Timestamp(6)
  dueDate     DateTime        @db.Timestamp(6)
  subtotal    Decimal         @db.Decimal(15, 2)
  taxAmount   Decimal         @default(0) @db.Decimal(15, 2)
  total       Decimal         @db.Decimal(15, 2)
  paidAmount  Decimal         @default(0) @db.Decimal(15, 2)
  status      ArInvoiceStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime        @default(now()) @db.Timestamp(6)
  updatedAt   DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  customer    Customer?       @relation(fields: [customerId], references: [id], onUpdate: NoAction)
  Tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, invoiceNo])
  @@index([tenantId], map: "idx_ar_tenant")
  @@index([tenantId, status], map: "idx_ar_tenant_status")
}

model ApBill {
  id         String       @id @default(cuid())
  tenantId   String
  vendorId   String
  billNo     String
  billDate   DateTime     @db.Timestamp(6)
  dueDate    DateTime     @db.Timestamp(6)
  subtotal   Decimal      @db.Decimal(15, 2)
  taxAmount  Decimal      @default(0) @db.Decimal(15, 2)
  whtAmount  Decimal      @default(0) @db.Decimal(15, 2)
  total      Decimal      @db.Decimal(15, 2)
  paidAmount Decimal      @default(0) @db.Decimal(15, 2)
  status     ApBillStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime     @default(now()) @db.Timestamp(6)
  updatedAt  DateTime     @default(now()) @updatedAt @db.Timestamp(6)
  Tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendor     Vendor       @relation(fields: [vendorId], references: [id], onUpdate: NoAction)

  @@unique([tenantId, billNo])
  @@index([tenantId], map: "idx_ap_tenant")
}

model CrmPipeline {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  stages    Json      @default("[]")
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  leads     CrmLead[]
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, name])
  @@index([tenantId], map: "idx_crm_pipeline_tenant")
}

model CrmLead {
  id                String        @id @default(cuid())
  tenantId          String
  customerId        String?
  ownerId           String?
  pipelineId        String?
  stage             String?
  source            String?
  name              String
  company           String?
  email             String?
  phone             String?
  value             Decimal       @default(0) @db.Decimal(15, 2)
  probability       Int           @default(0)
  status            CrmLeadStatus @default(NEW)
  expectedCloseDate DateTime?     @db.Timestamp(6)
  notes             String?
  createdAt         DateTime      @default(now()) @db.Timestamp(6)
  updatedAt         DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  activities        CrmActivity[]
  Customer          Customer?     @relation(fields: [customerId], references: [id], onUpdate: NoAction)
  User              User?         @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
  pipeline          CrmPipeline?  @relation(fields: [pipelineId], references: [id], onUpdate: NoAction)
  Tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_crm_lead_tenant")
  @@index([tenantId, ownerId], map: "idx_crm_lead_tenant_owner")
  @@index([tenantId, stage], map: "idx_crm_lead_tenant_stage")
  @@index([tenantId, status], map: "idx_crm_lead_tenant_status")
}

model CrmActivity {
  id          String          @id @default(cuid())
  tenantId    String
  leadId      String?
  userId      String
  type        CrmActivityType
  subject     String
  description String?
  dueAt       DateTime?       @db.Timestamp(6)
  completedAt DateTime?       @db.Timestamp(6)
  createdAt   DateTime        @default(now()) @db.Timestamp(6)
  lead        CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User        User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId], map: "idx_crm_activity_lead")
  @@index([tenantId], map: "idx_crm_activity_tenant")
}

model EmailMessage {
  id           String      @id @default(cuid())
  tenantId     String
  folder       String      @default("INBOX")
  from         String      @default("")
  senderId     String?
  fromAddress  String
  toAddresses  String[]
  ccAddresses  String[]    @default([])
  bccAddresses String[]    @default([])
  subject      String
  body         String      @default("")
  bodyHtml     String?
  bodyText     String?
  receivedAt   DateTime?   @db.Timestamp(6)
  status       EmailStatus @default(DRAFT)
  sentAt       DateTime?   @db.Timestamp(6)
  isRead       Boolean     @default(false)
  createdAt    DateTime    @default(now()) @db.Timestamp(6)
  updatedAt    DateTime    @default(now()) @db.Timestamp(6)
  User         User?       @relation(fields: [senderId], references: [id], onUpdate: NoAction)
  Tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_email_tenant")
  @@index([tenantId, folder], map: "idx_email_tenant_folder")
  @@index([tenantId, sentAt], map: "idx_email_tenant_sent")
  @@index([tenantId, status], map: "idx_email_tenant_status")
  @@index([tenantId, receivedAt], map: "idx_email_tenant_received")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  name      String
  subject   String
  body      String   @default("")
  bodyHtml  String
  variables String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(6)
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@unique([tenantId, name])
