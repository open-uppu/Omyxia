  Vendor       Vendor?       @relation(fields: [vendorId], references: [id], onUpdate: NoAction)

  @@unique([tenantId, invoiceNo])
  @@index([tenantId], map: "idx_invoice_tenant")
  @@index([tenantId, dueDate], map: "idx_invoice_tenant_due")
  @@index([tenantId, status], map: "idx_invoice_tenant_status")
}

