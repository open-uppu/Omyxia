// omyxia — Prisma schema (clean, validation-ready)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  plan        String   @default("STARTER")
  status      String   @default("ACTIVE")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        UserTenant[]
  employees    Employee[]
  departments  Department[]
  positions    Position[]

  @@index([slug])
  @@index([status])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String
  locale        String   @default("en")
  status        String   @default("ACTIVE")
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants       UserTenant[]
  sessions      UserSession[]
  mfaFactors    MfaFactor[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([status])
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("MEMBER") // OWNER | ADMIN | MEMBER | VIEWER
  status    String   @default("ACTIVE")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([role])
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  ip          String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Employee {
  id            String   @id @default(cuid())
  tenantId      String
  employeeNo    String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  departmentId  String?
  positionId    String?
  managerId     String?
  hireDate      DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department?  @relation(fields: [departmentId], references: [id])
  position      Position?    @relation(fields: [positionId], references: [id])
  manager       Employee?    @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  Employee[]   @relation("ManagerSubordinates")

  attendance    AttendanceRecord[]
  leaveRequests LeaveRequest[]
  payrollLines  PayrollLine[]

  @@unique([tenantId, employeeNo])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
}

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  parentId    String?
  managerId   String?
  costCenter  String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  employees   Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
}

model Position {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  title       String
  level       Int       @default(1)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model AttendanceRecord {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  date          DateTime @db.Date
  clockIn       DateTime?
  clockOut      DateTime?
  hoursWorked   Float?
  status        String   @default("PRESENT")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([employeeId])
  @@index([date])
}

model LeaveRequest {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  leaveType     String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  days          Int
  reason        String?
  status        String   @default("PENDING")
  approverId    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

model LeaveQuota {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  leaveType     String
  year          Int
  entitlement   Float
  used          Float    @default(0)
  remaining     Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, employeeId, leaveType, year])
  @@index([tenantId])
}

model PayrollPeriod {
  id            String   @id @default(cuid())
  tenantId      String
  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date
  status        String   @default("OPEN")
  totalGross    Float    @default(0)
  totalNet      Float    @default(0)
  totalTax      Float    @default(0)
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         PayrollLine[]

  @@unique([tenantId, periodStart])
  @@index([tenantId])
}

model PayrollLine {
  id            String   @id @default(cuid())
  tenantId      String
  periodId      String
  employeeId    String
  gross         Float
  tax           Float
  net           Float
  breakdown     Json     @default("{}")
  createdAt     DateTime @default(now())

  period        PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([periodId])
  @@index([employeeId])
}

model ChartOfAccounts {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          String
  parentId      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent        ChartOfAccounts?  @relation("COA_Hierarchy", fields: [parentId], references: [id])
  children      ChartOfAccounts[] @relation("COA_Hierarchy")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
}

model JournalEntry {
  id            String   @id @default(cuid())
  tenantId      String
  entryNo       String
  date          DateTime @db.Date
  description   String
  status        String   @default("POSTED")
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lines         JournalLine[]

  @@unique([tenantId, entryNo])
  @@index([tenantId])
  @@index([date])
}

model JournalLine {
  id            String   @id @default(cuid())
  tenantId      String
  entryId       String
  accountId     String
  debit         Float    @default(0)
  credit        Float    @default(0)
  description   String?

  entry         JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entryId])
  @@index([accountId])
}

model FiscalPeriod {
  id            String   @id @default(cuid())
  tenantId      String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  isClosed      Boolean  @default(false)
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, startDate])
  @@index([tenantId])
}

model TaxRate {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  rate          Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TaxTransaction {
  id            String   @id @default(cuid())
  tenantId      String
  date          DateTime @db.Date
  taxCode       String
  baseAmount    Float
  taxAmount     Float
  refType       String?
  refId         String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([date])
}

model Vendor {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  taxId         String?
  email         String?
  phone         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bills         ApBill[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  taxId         String?
  email         String?
  phone         String?
  address       String?
  creditLimit   Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices      ArInvoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ArInvoice {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceNo     String
  customerId    String
  invoiceDate   DateTime @db.Date
  dueDate       DateTime @db.Date
  subtotal      Float
  taxAmount     Float
  total         Float
  paidAmount    Float    @default(0)
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer @relation(fields: [customerId], references: [id])

  @@unique([tenantId, invoiceNo])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
}

model ApBill {
  id            String   @id @default(cuid())
  tenantId      String
  billNo        String
  vendorId      String
  billDate      DateTime @db.Date
  dueDate       DateTime @db.Date
  subtotal      Float
  taxAmount     Float
  total         Float
  paidAmount    Float    @default(0)
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor        Vendor @relation(fields: [vendorId], references: [id])

  @@unique([tenantId, billNo])
  @@index([tenantId])
  @@index([vendorId])
  @@index([status])
}

model CrmPipeline {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         CrmLead[]

  @@index([tenantId])
}

model CrmLead {
  id            String   @id @default(cuid())
  tenantId      String
  pipelineId    String
  name          String
  contactEmail  String?
  contactPhone  String?
  source        String?
  stage         String   @default("NEW")
  score         Int      @default(0)
  estimatedValue Float   @default(0)
  ownerId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pipeline      CrmPipeline    @relation(fields: [pipelineId], references: [id])
  activities    CrmActivity[]

  @@index([tenantId])
  @@index([pipelineId])
  @@index([stage])
}

model CrmActivity {
  id            String   @id @default(cuid())
  tenantId      String
  leadId        String
  type          String
  subject       String
  body          String?
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lead          CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leadId])
}

model EmailMessage {
  id            String   @id @default(cuid())
  tenantId      String
  folder        String   @default("INBOX")
  from          String
  to            String
  subject       String
  body          String
  isRead        Boolean  @default(false)
  receivedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([folder])
}

model EmailTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  subject       String
  body          String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ChatChannel {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  isPrivate     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       ChatChannelMember[]
  messages      ChatMessage[]

  @@index([tenantId])
}

model ChatChannelMember {
  id            String   @id @default(cuid())
  tenantId      String
  channelId     String
  userId        String
  joinedAt      DateTime @default(now())

  channel       ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([tenantId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  tenantId      String
  channelId     String
  userId        String
  body          String
  editedAt      DateTime?
  createdAt     DateTime @default(now())

  channel       ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([channelId])
}

model FileFolder {
  id            String   @id @default(cuid())
  tenantId      String
  parentId      String?
  name          String
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent        FileFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children      FileFolder[] @relation("FolderHierarchy")
  files         FileItem[]

  @@index([tenantId])
  @@index([parentId])
}

model FileItem {
  id            String   @id @default(cuid())
  tenantId      String
  folderId      String?
  name          String
  mimeType      String
  size          Int
  storageKey    String
  checksum      String?
  uploadedBy    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  folder        FileFolder? @relation(fields: [folderId], references: [id])

  @@index([tenantId])
  @@index([folderId])
}

model MfaFactor {
  id            String   @id @default(cuid())
  userId        String
  type          String
  secret        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String?
  action        String
  resourceType  String
  resourceId    String?
  ip            String?
  userAgent     String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  user          User? @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model CreditAssessment {
  id            String   @id @default(cuid())
  tenantId      String
  customerId    String
  score         Int
  riskLevel     String
  notes         String?
  assessedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
}

model CashFlowForecast {
  id            String   @id @default(cuid())
  tenantId      String
  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date
  openingBalance Float
  inflow        Float    @default(0)
  outflow       Float    @default(0)
  closingBalance Float
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([periodStart])
}

model FraudAlert {
  id            String   @id @default(cuid())
  tenantId      String
  source        String
  severity      String
  status        String   @default("OPEN")
  description   String
  metadata      Json     @default("{}")
  detectedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([severity])
  @@index([status])
}

model MarketingCampaign {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  channel       String
  status        String   @default("DRAFT")
  startDate     DateTime?
  endDate       DateTime?
  budget        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

model CustomerProfile {
  id            String   @id @default(cuid())
  tenantId      String
  customerId    String
  traits        Json     @default("{}")
  preferences   Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, customerId])
  @@index([tenantId])
}

model CustomerEvent {
  id            String   @id @default(cuid())
  tenantId      String
  customerId    String
  eventType     String
  payload       Json     @default("{}")
  occurredAt    DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([occurredAt])
}

model Project {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks         ProjectTask[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model ProjectTask {
  id            String   @id @default(cuid())
  tenantId      String
  projectId     String
  parentId      String?
  title         String
  description   String?
  assigneeId    String?
  status        String   @default("TODO")
  priority      String   @default("NORMAL")
  startDate     DateTime?
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
}

model DocumentTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  content       String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  instances     DocumentInstance[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model DocumentInstance {
  id            String   @id @default(cuid())
  tenantId      String
  templateId    String
  title         String
  payload       Json     @default("{}")
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  template      DocumentTemplate @relation(fields: [templateId], references: [id])

  @@index([tenantId])
  @@index([templateId])
}

model Warehouse {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  location      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventory     InventoryItem[]
  movements     StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  warehouseId   String
  sku           String
  name          String
  uom           String   @default("EA")
  quantity      Float    @default(0)
  reorderPoint  Float    @default(0)
  unitCost      Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([warehouseId])
}

model StockMovement {
  id            String   @id @default(cuid())
  tenantId      String
  warehouseId   String
  itemId        String
  type          String
  quantity      Float
  reference     String?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([warehouseId])
  @@index([itemId])
}

model SupplierScore {
  id            String   @id @default(cuid())
  tenantId      String
  supplierId    String
  score         Int
  criteria      Json     @default("{}")
  evaluatedAt   DateTime @default(now())

  @@index([tenantId])
  @@index([supplierId])
}

model Ticket {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  subject       String
  description   String?
  status        String   @default("OPEN")
  priority      String   @default("NORMAL")
  assigneeId    String?
  reporterId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
}

model Vehicle {
  id            String   @id @default(cuid())
  tenantId      String
  plateNo       String
  model         String
  type          String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips         VehicleTrip[]

  @@unique([tenantId, plateNo])
  @@index([tenantId])
}

model VehicleTrip {
  id            String   @id @default(cuid())
  tenantId      String
  vehicleId     String
  driverId      String
  startAt       DateTime
  endAt         DateTime?
  startKm       Int
  endKm         Int?
  purpose       String?
  createdAt     DateTime @default(now())

  vehicle       Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([vehicleId])
}

model Device {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  type          String
  status        String   @default("ONLINE")
  lastSeen      DateTime?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  threats       ThreatEvent[]

  @@index([tenantId])
  @@index([status])
}

model ThreatEvent {
  id            String   @id @default(cuid())
  tenantId      String
  deviceId      String
  severity      String
  type          String
  description   String
  detectedAt    DateTime @default(now())
  resolvedAt    DateTime?

  device        Device @relation(fields: [deviceId], references: [id])

  @@index([tenantId])
  @@index([deviceId])
  @@index([severity])
}

model BackupRecord {
  id            String   @id @default(cuid())
  tenantId      String
  resource      String
  status        String
  size          Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  storageKey    String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([status])
}

model ConsentRecord {
  id            String   @id @default(cuid())
  tenantId      String
  subjectId     String
  purpose       String
  granted       Boolean
  source        String?
  capturedAt    DateTime @default(now())

  @@index([tenantId])
  @@index([subjectId])
}

model DataSubjectRequest {
  id            String   @id @default(cuid())
  tenantId      String
  subjectId     String
  type          String
  status        String   @default("RECEIVED")
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

model CookieConsent {
  id            String   @id @default(cuid())
  tenantId      String
  visitorId     String
  categories    Json     @default("{}")
  capturedAt    DateTime @default(now())

  @@index([tenantId])
  @@index([visitorId])
}

model PrivacyPolicy {
  id            String   @id @default(cuid())
  tenantId      String
  version       String
  content       String
  effectiveAt   DateTime
  createdAt     DateTime @default(now())

  @@unique([tenantId, version])
  @@index([tenantId])
}

model DataBreachIncident {
  id            String   @id @default(cuid())
  tenantId      String
  severity      String
  description   String
  affectedCount Int      @default(0)
  detectedAt    DateTime @default(now())
  reportedAt    DateTime?
  resolvedAt    DateTime?

  @@index([tenantId])
  @@index([severity])
}

model Dashboard {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  layout        Json     @default("{}")
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     ReportSnapshot[]

  @@index([tenantId])
}

model ReportSnapshot {
  id            String   @id @default(cuid())
  tenantId      String
  dashboardId   String
  data          Json
  generatedAt   DateTime @default(now())

  dashboard     Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dashboardId])
}

model KpiDefinition {
  id            String   @id @default(cuid())
  tenantId      String
  code          String
  name          String
  unit          String?
  query         String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots     KpiSnapshot[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model KpiSnapshot {
  id            String   @id @default(cuid())
  tenantId      String
  kpiId         String
  period        DateTime @db.Date
  value         Float
  metadata      Json     @default("{}")
  capturedAt    DateTime @default(now())

  kpi           KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([kpiId])
  @@index([period])
}
